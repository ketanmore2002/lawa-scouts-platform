# ── Required ──
OPENAI_API_KEY=sk-your-key-here
DATABASE_URL=sqlite+aiosqlite:///./scouts.db
SECRET_KEY=change-me-in-production

# ── Auth ──
LAWA_API_URL=https://lawa.app
ADMIN_EMAILS=admin@example.com

# ── Optional: Product Search ──
SERPAPI_KEY=

# ── Optional: Sandbox (charts & file exports) ──
E2B_API_KEY=

# ── Optional: Multi-worker scaling ──
REDIS_URL=
ENABLE_SCHEDULER=true
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Email ──
EMAIL_FROM=contact@lawa.app
EMAIL_HOST_PASSWORD=
BASE_URL=https://lawa.app
